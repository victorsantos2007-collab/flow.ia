const SC={home:'screen-home',metodo:'screen-metodo',nicho:'screen-nicho',scripts:'screen-scripts',checklist:'screen-checklist',faq:'screen-faq'};
const SB={home:'sb-home',metodo:'sb-metodo',nicho:'sb-nicho',scripts:'sb-scripts',checklist:'sb-checklist',faq:'sb-faq'};
