const sob  = p.get('sobrenome') || 'Silva';
const plano= p.get('plano') || 'free';

document.getElementById('h-name').textContent  = nome;
document.getElementById('tb-name').textContent = nome;
document.getElementById('sb-av').textContent   = (nome[0]+(sob[0]||'S')).toUpperCase();

const plabels = {free:'GRATUITO',starter:'STARTER',pro:'PRO',elite:'ELITE'};
const pclass  = {free:'chip-free',starter:'chip-starter',pro:'chip-pro',elite:'chip-elite'};
const chip = document.getElementById('plan-chip');
chip.textContent = plabels[plano]||'GRATUITO';
chip.className   = 'plan-chip '+(pclass[plano]||'chip-free');

/* ── STATE ── */
const KEY = 'afsteps_'+nome;
let ST = JSON.parse(localStorage.getItem(KEY)||'{}');
function save(){ localStorage.setItem(KEY,JSON.stringify(ST)); }

/* ── DONE ── */
function done(n){
  ST[n]=true; save(); refresh();
  const nxt={1:'nicho',2:'scripts',3:'checklist',4:'checklist',5:'home'};
  if(nxt[n]) goto(nxt[n]);
}

/* ── REFRESH UI ── */
function refresh(){
  const cnt = Object.values(ST).filter(Boolean).length;
  const pct = Math.round((cnt/5)*100);
  document.getElementById('tbar-fill').style.width=pct+'%';
  document.getElementById('tracker-pct').textContent=cnt+' / 5';
  document.getElementById('stat-pct').textContent=pct+'%';
  document.getElementById('stat-sub').textContent=cnt+' de 5 passos feitos';
  const nl={0:'Passo 1',1:'Passo 2',2:'Passo 3',3:'Passo 4',4:'Passo 5',5:'🏆 Completo!'};
  document.getElementById('stat-next').textContent=nl[cnt]||'Completo!';

  const screens_map=['si1','si2','si3','si4','si5'];
  const screen_ids =['metodo','nicho','scripts','checklist','checklist'];
  screens_map.forEach((id,i)=>{
    const el=document.getElementById(id);
    if(!el)return;
    const bd=el.querySelector('.s-badge');
    if(ST[i+1]){
      el.className='step-item done';
      el.onclick=null; el.style.pointerEvents='none';
      if(bd){bd.textContent='✓ FEITO';bd.className='s-badge sb-done';}
    } else if(i>0 && !ST[i]){
      el.className='step-item locked';
      el.style.pointerEvents='none';
      if(bd){bd.textContent='🔒';bd.className='s-badge sb-lock';}
    } else {
      el.className='step-item current';
      el.style.pointerEvents='';
      const sid=screen_ids[i];
      el.onclick=()=>goto(sid);
      if(bd){bd.textContent='AGORA';bd.className='s-badge sb-now';}
    }
  });

  // lock walls
  const lN=document.getElementById('nicho-lock'),cN=document.getElementById('nicho-content');
  if(lN&&cN){const l=!ST[1];lN.style.display=l?'block':'none';cN.style.display=l?'none':'block';}
  const lS=document.getElementById('scripts-lock'),cS=document.getElementById('scripts-content');
  if(lS&&cS){const l=!ST[1]||!ST[2];lS.style.display=l?'block':'none';cS.style.display=l?'none':'block';}
  const lC=document.getElementById('ck-lock'),cC=document.getElementById('ck-content');
  if(lC&&cC){const l=!ST[1]||!ST[2]||!ST[3];lC.style.display=l?'block':'none';cC.style.display=l?'none':'block';}
}

