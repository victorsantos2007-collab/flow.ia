<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AutoFlow IA — Sua Área</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#080C12;
  --s1:#0D1219;
  --s2:#121A24;
  --s3:#18222E;
  --border:#1E2D3D;
  --border2:#243548;
  --cyan:#00E5FF;
  --green:#39FF6E;
  --yellow:#FFD600;
  --orange:#FF7A00;
  --white:#F4F8FF;
  --dim:#8CA0BC;
  --dimmer:#4A5F78;
  --red:#FF4560;
  --font:'Plus Jakarta Sans',sans-serif;
  --display:'Syne',sans-serif;
  --mono:'DM Mono',monospace;
}
html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--bg);color:var(--white);min-height:100vh;overflow-x:hidden}

.layout{display:flex;min-height:100vh}

/* ─── SIDEBAR ─── */
.sidebar{
  width:72px;flex-shrink:0;background:var(--s1);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;align-items:center;
  padding:1.2rem 0;gap:.4rem;
  position:sticky;top:0;height:100vh;z-index:50;
}
.sb-logo{font-family:var(--display);font-weight:800;font-size:.75rem;color:var(--cyan);text-align:center;padding:.4rem;line-height:1.1;margin-bottom:.4rem}
.sb-sep{width:32px;height:1px;background:var(--border);margin:.2rem 0}
.sb-btn{
  width:44px;height:44px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.15rem;cursor:pointer;border:none;background:transparent;
  transition:background .15s;position:relative;
}
.sb-btn:hover{background:var(--s3)}
.sb-btn.active{background:rgba(0,229,255,.12)}
.sb-btn.active::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:22px;background:var(--cyan);border-radius:0 3px 3px 0}
.sb-tip{position:absolute;left:56px;background:var(--s3);border:1px solid var(--border2);color:var(--white);font-size:.7rem;font-weight:600;padding:.25rem .6rem;border-radius:6px;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s;z-index:99}
.sb-btn:hover .sb-tip{opacity:1}
.sb-spacer{flex:1}
.sb-avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--cyan),var(--green));display:flex;align-items:center;justify-content:center;font-family:var(--display);font-weight:800;font-size:.7rem;color:var(--bg);cursor:pointer}

/* ─── MAIN ─── */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}

.topbar{
  height:56px;flex-shrink:0;background:var(--s1);border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 1.5rem;position:sticky;top:0;z-index:40;
}
.topbar-left{display:flex;align-items:center;gap:.8rem;min-width:0}
.page-title{font-family:var(--display);font-size:.9rem;font-weight:700;color:var(--white);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.plan-chip{font-size:.6rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.18rem .6rem;border-radius:20px;border:1px solid;flex-shrink:0}
.chip-free{border-color:var(--dimmer);color:var(--dimmer)}
.chip-starter{border-color:var(--cyan);color:var(--cyan);background:rgba(0,229,255,.07)}
.chip-pro{border-color:var(--green);color:var(--green);background:rgba(57,255,110,.07)}
.chip-elite{border-color:var(--yellow);color:var(--yellow);background:rgba(255,214,0,.07)}
.topbar-right{display:flex;align-items:center;gap:.7rem;flex-shrink:0}
.topbar-user{font-size:.8rem;color:var(--dim)}
.notif-btn{width:30px;height:30px;border-radius:7px;border:1px solid var(--border);background:transparent;display:flex;align-items:center;justify-content:center;font-size:.85rem;cursor:pointer;transition:background .15s}
.notif-btn:hover{background:var(--s3)}

.content{flex:1;overflow-y:auto;padding:1.5rem}
.screen{display:none}
.screen.active{display:block;animation:scIn .28s ease both}
@keyframes scIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* ─── WELCOME HERO ─── */
.welcome-hero{
  background:linear-gradient(135deg,var(--s2),rgba(0,229,255,.03));
  border:1px solid var(--border);border-radius:14px;
  padding:1.8rem 2rem;margin-bottom:1.2rem;position:relative;overflow:hidden;
}
.welcome-hero::after{content:'';position:absolute;top:-30px;right:-30px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(0,229,255,.07),transparent 70%);pointer-events:none}
.wh-tag{display:inline-flex;align-items:center;gap:.4rem;font-size:.65rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--cyan);margin-bottom:.6rem}
.pulse{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)}}
.welcome-hero h1{font-family:var(--display);font-size:clamp(1.3rem,2.5vw,1.8rem);font-weight:800;color:var(--white);letter-spacing:-.03em;margin-bottom:.4rem}
.welcome-hero h1 em{font-style:normal;color:var(--cyan)}
.welcome-hero p{font-size:.85rem;color:var(--dim);line-height:1.6;max-width:500px}
.wh-cta{margin-top:1.1rem;display:inline-flex;align-items:center;gap:.5rem;background:var(--cyan);color:var(--bg);padding:.6rem 1.3rem;border-radius:8px;font-family:var(--display);font-size:.8rem;font-weight:800;border:none;cursor:pointer;box-shadow:0 0 20px rgba(0,229,255,.22);transition:transform .15s,box-shadow .15s}
.wh-cta:hover{transform:translateY(-2px);box-shadow:0 0 35px rgba(0,229,255,.38)}

/* ─── STATS ─── */
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:.8rem;margin-bottom:1.2rem}
.stat-card{background:var(--s2);border:1px solid var(--border);border-radius:12px;padding:1.1rem}
.stat-label{font-size:.65rem;color:var(--dim);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.3rem}
.stat-val{font-family:var(--display);font-size:1.5rem;font-weight:800;color:var(--white);letter-spacing:-.03em;line-height:1}
.stat-sub{font-size:.7rem;color:var(--green);margin-top:.25rem;font-weight:600}

/* ─── STEP TRACKER ─── */
.tracker{background:var(--s2);border:1px solid var(--border);border-radius:14px;padding:1.4rem}
.tracker-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem}
.tracker-hd h2{font-family:var(--display);font-size:.95rem;font-weight:800;color:var(--white)}
.tracker-pct{font-family:var(--mono);font-size:.75rem;color:var(--cyan)}
.tbar{height:4px;background:var(--border);border-radius:2px;margin-bottom:1.2rem;overflow:hidden}
.tbar-fill{height:100%;background:linear-gradient(90deg,var(--cyan),var(--green));border-radius:2px;transition:width 1s ease}

.step-rows{display:flex;flex-direction:column;gap:.4rem}
.step-item{
  display:flex;align-items:center;gap:.9rem;
  padding:.95rem 1.1rem;border-radius:10px;border:1px solid var(--border);
  cursor:pointer;transition:all .18s;position:relative;
}
.step-item.current{background:rgba(0,229,255,.04);border-color:rgba(0,229,255,.28)}
.step-item.done{background:rgba(57,255,110,.02);border-color:rgba(57,255,110,.18)}
.step-item.locked{opacity:.38;cursor:not-allowed;pointer-events:none}
.step-item:not(.locked):not(.done):hover{background:var(--s3)}

.s-ico{width:38px;height:38px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1rem;border:2px solid var(--border);background:var(--s1);transition:all .18s}
.step-item.current .s-ico{border-color:var(--cyan);background:rgba(0,229,255,.1)}
.step-item.done .s-ico{border-color:var(--green);background:rgba(57,255,110,.1)}

.s-info{flex:1;min-width:0}
.s-info h3{font-size:.88rem;font-weight:700;color:var(--white);margin-bottom:.15rem}
.s-info p{font-size:.73rem;color:var(--dim);line-height:1.4;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

.s-badge{font-size:.62rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:.17rem .5rem;border-radius:20px;flex-shrink:0}
.sb-now{background:rgba(0,229,255,.15);color:var(--cyan);border:1px solid rgba(0,229,255,.3)}
.sb-done{background:rgba(57,255,110,.12);color:var(--green);border:1px solid rgba(57,255,110,.2)}
.sb-lock{background:rgba(74,95,120,.08);color:var(--dimmer);border:1px solid var(--border)}

/* ─── SECTION LABEL ─── */
.sec-lbl{font-size:.65rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--dim);margin-bottom:.9rem;display:flex;align-items:center;gap:.6rem}
.sec-lbl::after{content:'';flex:1;height:1px;background:var(--border)}

/* ─── METHOD HERO ─── */
.mhero{border-radius:14px;padding:1.8rem;margin-bottom:1.2rem;position:relative;overflow:hidden}
.mhero.c1{background:linear-gradient(135deg,rgba(0,229,255,.07),rgba(0,229,255,.02));border:1px solid rgba(0,229,255,.18)}
.mhero.c2{background:linear-gradient(135deg,rgba(57,255,110,.07),rgba(57,255,110,.02));border:1px solid rgba(57,255,110,.18)}
.mhero.c3{background:linear-gradient(135deg,rgba(255,214,0,.07),rgba(255,214,0,.02));border:1px solid rgba(255,214,0,.18)}
.mhero.c4{background:linear-gradient(135deg,rgba(255,122,0,.07),rgba(255,122,0,.02));border:1px solid rgba(255,122,0,.18)}
.mhero-top{display:flex;align-items:center;justify-content:space-between;gap.5rem;margin-bottom:.8rem}
.mhero-step{font-family:var(--mono);font-size:.62rem;letter-spacing:.09em;text-transform:uppercase;color:var(--dim);background:rgba(0,0,0,.25);padding:.18rem .55rem;border-radius:4px}
.mhero-time{font-size:.7rem;font-weight:700;color:var(--green);background:rgba(57,255,110,.1);border:1px solid rgba(57,255,110,.2);padding:.18rem .55rem;border-radius:4px}
.mhero h2{font-family:var(--display);font-size:clamp(1.1rem,2vw,1.4rem);font-weight:800;color:var(--white);margin-bottom:.4rem;letter-spacing:-.02em}
.mhero p{font-size:.83rem;color:var(--dim);line-height:1.6;max-width:600px}
.tools-row{display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.9rem}
.tool-tag{display:inline-flex;align-items:center;gap:.3rem;padding:.25rem .65rem;border-radius:20px;font-size:.65rem;font-weight:600;background:var(--s1);border:1px solid var(--border2);color:var(--dim)}
.tool-dot{width:5px;height:5px;border-radius:50%;background:var(--cyan)}

/* ─── HOW GRID ─── */
.how-grid{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin-bottom:1.2rem}
.how-card{background:var(--s2);border:1px solid var(--border);border-radius:12px;padding:1.2rem;position:relative}
.how-n{font-family:var(--display);font-size:2.2rem;font-weight:800;color:rgba(255,255,255,.04);line-height:1;position:absolute;top:.9rem;right:1rem;letter-spacing:-.05em}
.how-card h4{font-size:.85rem;font-weight:700;color:var(--white);margin-bottom:.35rem}
.how-card p{font-size:.76rem;color:var(--dim);line-height:1.6}
.how-t{display:inline-block;margin-top:.7rem;font-family:var(--mono);font-size:.62rem;color:var(--cyan)}

/* ─── SCRIPT ─── */
.script-wrap{background:var(--s2);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:1.2rem}
.script-bar{display:flex;align-items:center;justify-content:space-between;padding:.6rem 1rem;background:var(--s1);border-bottom:1px solid var(--border)}
.script-dots{display:flex;gap:.3rem;align-items:center}
.sdot{width:8px;height:8px;border-radius:50%}
.script-bar-title{font-size:.68rem;color:var(--dim);margin-left:.4rem}
.btn-copy{padding:.28rem .75rem;border-radius:5px;background:transparent;border:1px solid var(--border2);color:var(--dim);font-size:.68rem;font-family:var(--mono);cursor:pointer;transition:all .15s}
.btn-copy:hover{border-color:var(--cyan);color:var(--cyan)}
.btn-copy.ok{border-color:var(--green);color:var(--green)}
.script-body{padding:1.1rem 1.3rem;font-family:var(--mono);font-size:.78rem;color:var(--white);line-height:1.85;white-space:pre-wrap}
.script-body mark{background:rgba(0,229,255,.13);color:var(--cyan);border-radius:3px;padding:0 .18rem;font-style:normal}

/* ─── ACTION BAR ─── */
.action-bar{display:flex;align-items:center;justify-content:space-between;background:var(--s2);border:1px solid var(--border);border-radius:12px;padding:1.1rem 1.3rem;margin-bottom:1.2rem;flex-wrap:wrap;gap:.8rem}
.ab-info h4{font-size:.88rem;font-weight:700;color:var(--white);margin-bottom:.15rem}
.ab-info p{font-size:.75rem;color:var(--dim)}
.ab-btns{display:flex;gap:.6rem;align-items:center;flex-shrink:0}
.btn-p{display:inline-flex;align-items:center;gap:.4rem;padding:.6rem 1.2rem;border-radius:8px;background:var(--cyan);color:var(--bg);font-family:var(--display);font-size:.78rem;font-weight:800;border:none;cursor:pointer;text-decoration:none;box-shadow:0 0 18px rgba(0,229,255,.2);transition:transform .15s,box-shadow .15s}
.btn-p:hover{transform:translateY(-2px);box-shadow:0 0 28px rgba(0,229,255,.35)}
.btn-s{display:inline-flex;align-items:center;gap:.4rem;padding:.6rem 1rem;border-radius:8px;background:transparent;color:var(--dim);font-family:var(--display);font-size:.78rem;font-weight:700;border:1px solid var(--border2);cursor:pointer;text-decoration:none;transition:border-color .15s,color .15s}
.btn-s:hover{border-color:var(--white);color:var(--white)}

/* ─── LOCK WALL ─── */
.lock-wall{background:var(--s2);border:1px solid var(--border);border-radius:12px;padding:2rem;text-align:center;margin-bottom:1.2rem}
.lock-wall .lock-ico{font-size:2rem;margin-bottom:.8rem}
.lock-wall h3{font-family:var(--display);font-size:.95rem;font-weight:800;color:var(--white);margin-bottom:.4rem}
.lock-wall p{font-size:.8rem;color:var(--dim);margin-bottom:1rem;line-height:1.55}

/* ─── NICHO GRID ─── */
.nicho-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.7rem;margin-bottom:1.2rem}
.nicho-btn{background:var(--s2);border:2px solid var(--border);border-radius:12px;padding:1rem .7rem;text-align:center;cursor:pointer;transition:all .18s}
.nicho-btn:hover{border-color:var(--cyan);background:rgba(0,229,255,.04);transform:translateY(-3px)}
.nicho-btn.sel{border-color:var(--green);background:rgba(57,255,110,.05)}
.ni-em{font-size:1.6rem;margin-bottom:.4rem;display:block}
.ni-nm{font-size:.75rem;font-weight:700;color:var(--white);margin-bottom:.15rem}
.ni-tk{font-family:var(--mono);font-size:.6rem;color:var(--dim)}
.nicho-btn.sel .ni-nm{color:var(--green)}

/* ─── UPGRADE BANNER ─── */
.up-banner{background:linear-gradient(135deg,rgba(0,229,255,.06),rgba(57,255,110,.04));border:1px solid rgba(0,229,255,.18);border-radius:12px;padding:1.3rem;display:flex;align-items:center;gap:1.2rem;flex-wrap:wrap;margin-top:1.2rem}
.up-banner h3{font-family:var(--display);font-size:.9rem;font-weight:800;color:var(--white);margin-bottom:.25rem}
.up-banner p{font-size:.78rem;color:var(--dim);line-height:1.5;max-width:400px}
.btn-up{flex-shrink:0;padding:.6rem 1.3rem;border-radius:8px;background:var(--cyan);color:var(--bg);font-family:var(--display);font-size:.78rem;font-weight:800;text-decoration:none;white-space:nowrap;box-shadow:0 0 20px rgba(0,229,255,.22);transition:transform .15s}
.btn-up:hover{transform:translateY(-2px)}

/* ─── CHECKLIST ─── */
.cklist{background:var(--s2);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:1.2rem}
.ck-row{display:flex;align-items:flex-start;gap:.8rem;padding:.85rem 1.1rem;cursor:pointer;transition:background .15s;border-bottom:1px solid var(--border)}
.ck-row:last-child{border-bottom:none}
.ck-row:hover{background:var(--s3)}
.ck-box{width:19px;height:19px;flex-shrink:0;margin-top:.05rem;border-radius:5px;border:2px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:.72rem;transition:all .18s}
.ck-row.ticked .ck-box{background:var(--green);border-color:var(--green);color:var(--bg)}
.ck-row.ticked .ck-txt{text-decoration:line-through;color:var(--dimmer)}
.ck-txt{font-size:.83rem;color:var(--white);line-height:1.5}
.ck-txt strong{color:var(--yellow)}

/* ─── PRICE TABLE ─── */
.price-mini{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin:.8rem 0}
.pm-card{background:var(--s1);border:1px solid var(--border);border-radius:8px;padding:.8rem}
.pm-lbl{font-size:.68rem;color:var(--dim);margin-bottom:.2rem}
.pm-val{font-family:var(--mono);font-size:.95rem;color:var(--green);font-weight:500}

/* ─── FAQ ─── */
.faq-card{background:var(--s2);border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:.4rem}
.faq-q{width:100%;text-align:left;background:none;border:none;color:var(--white);font-family:var(--font);font-size:.85rem;font-weight:600;padding:.95rem 1.1rem;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap.5rem;transition:color .15s}
.faq-q:hover{color:var(--cyan)}
.faq-ico{color:var(--dim);transition:transform .22s;flex-shrink:0}
.faq-card.open .faq-ico{transform:rotate(45deg);color:var(--cyan)}
.faq-a{max-height:0;overflow:hidden;font-size:.8rem;color:var(--dim);line-height:1.65;transition:max-height .28s,padding .28s;padding:0 1.1rem}
.faq-card.open .faq-a{max-height:160px;padding:.1rem 1.1rem .95rem}

/* ─── MOBILE ─── */
@media(max-width:768px){
  .sidebar{display:none}
  .how-grid{grid-template-columns:1fr}
  .nicho-grid{grid-template-columns:repeat(2,1fr)}
  .stats-row{grid-template-columns:1fr 1fr}
  .content{padding:1rem}
  .topbar{padding:0 1rem}
  .up-banner{flex-direction:column}
  .price-mini{grid-template-columns:1fr 1fr}
}
@media(max-width:420px){
  .stats-row{grid-template-columns:1fr}
  .price-mini{grid-template-columns:1fr}
  .nicho-grid{grid-template-columns:repeat(2,1fr)}
}
</style>
</head>
<body>
<div class="layout">

<!-- SIDEBAR -->
<nav class="sidebar">
  <div class="sb-logo">AF<br>IA</div>
  <div class="sb-sep"></div>
  <button class="sb-btn active" id="sb-home" onclick="goto('home')">🏠<span class="sb-tip">Início</span></button>
  <button class="sb-btn" id="sb-metodo" onclick="goto('metodo')">🔧<span class="sb-tip">Passo 1 — Método</span></button>
  <button class="sb-btn" id="sb-nicho" onclick="goto('nicho')">🗺️<span class="sb-tip">Passo 2 — Nicho</span></button>
  <button class="sb-btn" id="sb-scripts" onclick="goto('scripts')">📝<span class="sb-tip">Passo 3 — Scripts</span></button>
  <button class="sb-btn" id="sb-checklist" onclick="goto('checklist')">✅<span class="sb-tip">Passos 4&5 — Reunião</span></button>
  <button class="sb-btn" id="sb-faq" onclick="goto('faq')">💬<span class="sb-tip">Dúvidas</span></button>
  <div class="sb-spacer"></div>
  <div class="sb-avatar" id="sb-av">JO</div>
</nav>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div class="topbar-left">
      <span class="page-title" id="pg-title">Início</span>
      <span class="plan-chip chip-free" id="plan-chip">GRATUITO</span>
    </div>
    <div class="topbar-right">
      <span class="topbar-user">Olá, <strong id="tb-name">João</strong> 👋</span>
      <button class="notif-btn">🔔</button>
    </div>
  </div>

  <div class="content">

    <!-- ████ HOME ████ -->
    <div class="screen active" id="screen-home">

      <div class="welcome-hero">
        <div class="wh-tag"><span class="pulse"></span>Área liberada</div>
        <h1>Olá, <em id="h-name">João</em>! Hora de começar. 💸</h1>
        <p>Siga os <strong style="color:var(--white)">5 passos na ordem.</strong> Cada um tem instruções claras e leva menos de 1 hora. Feito para quem tem pouco tempo.</p>
        <button class="wh-cta" onclick="goto('metodo')">Começar — Passo 1 →</button>
      </div>

      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-label">Progresso geral</div>
          <div class="stat-val" id="stat-pct">0%</div>
          <div class="stat-sub" id="stat-sub">0 de 5 passos feitos</div>
        </div>
